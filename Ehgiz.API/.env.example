# Copy this file to ".env" in the same folder and fill in real values.
# ".env" is gitignored and must never be committed.

ConnectionStrings__DefaultConnection=

Jwt__Key=

Stripe__SecretKey=
Stripe__PublishableKey=
Stripe__WebhookSecret=

SendGrid__ApiKey=

# GitHub Models (https://models.github.ai/inference) - one API key shared by the AI
# assistant (AI__Model) and the vision/photo-search features (GitHubModels__Model),
# each of which can use a different model.
AI__ApiKey=
GitHubModels__Model=openai/gpt-4o

CloudinarySettings__CloudName=
CloudinarySettings__ApiKey=
CloudinarySettings__ApiSecret=
